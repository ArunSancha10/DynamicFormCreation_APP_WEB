@model List<DynamicFormCreation.Web.Models.HomeModel>

<h2>Form List</h2>

<table border="1">
    <tr>
        <th>ID</th>
        <th>Name</th>
        <th>Description</th>
    </tr>

    @foreach (var item in Model)
    {
        <tr>
            <td>@item.Id</td>
            <td>@item.FormName</td>
            <td>@item.Description</td>
        </tr>
    }
</table>
